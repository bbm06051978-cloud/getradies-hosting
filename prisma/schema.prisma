generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  phone            String?
  role             UserRole       @default(HOMEOWNER)
  passwordHash     String
  suburb           String?
  state            String?
  postcode         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  jobs             Job[]
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]
  notifications    Notification[]
  reviews          Review[]
  tradieProfile    TradieProfile?
}

model TradieProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  businessName       String
  specialty          String
  licenseNumber      String?
  isVerified         Boolean          @default(false)
  rating             Float            @default(0)
  totalReviews       Int              @default(0)
  bio                String?
  suburb             String?
  state              String?
  profilePhoto       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  getradiePoints     Int?             @default(0)
  pointsBadge        String?          @default("Bronze")
  subscriptionPlan   String?          @default("Free")
  subscriptionExpiry DateTime?        @db.Timestamp(6)
  freeQuotesUsed     Int?             @default(0)
  bookings           Booking[]
  quotes             Quote[]
  documents          TradieDocument[]
  photos             TradiePhoto[]
  user               User             @relation(fields: [userId], references: [id])
}

model Job {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String
  trade       String
  suburb      String
  state       String
  postcode    String?
  status      JobStatus  @default(OPEN)
  aiEstimate  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookings    Booking[]
  user        User       @relation(fields: [userId], references: [id])
  photos      JobPhoto[]
  messages    Message[]
  quotes      Quote[]
}

model Quote {
  id              String        @id @default(cuid())
  jobId           String
  tradieProfileId String
  amount          Float
  description     String
  status          QuoteStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id])
  tradieProfile   TradieProfile @relation(fields: [tradieProfileId], references: [id])
}

model Booking {
  id              String        @id @default(cuid())
  jobId           String
  tradieProfileId String
  scheduledAt     DateTime
  status          BookingStatus @default(PENDING)
  totalAmount     Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id])
  tradieProfile   TradieProfile @relation(fields: [tradieProfileId], references: [id])
  payment         Payment?
  review          Review?
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  amount        Float
  status        String    @default("pending")
  method        String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  getradieFee   Float?    @default(0)
  tradieEarning Float?    @default(0)
  booking       Booking   @relation(fields: [bookingId], references: [id])
}

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  url       String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id])
}

model TradiePhoto {
  id              String        @id @default(cuid())
  tradieProfileId String
  url             String
  caption         String?
  createdAt       DateTime      @default(now())
  tradieProfile   TradieProfile @relation(fields: [tradieProfileId], references: [id])
}

model TradieDocument {
  id              String        @id @default(cuid())
  tradieProfileId String
  url             String
  type            String
  createdAt       DateTime      @default(now())
  tradieProfile   TradieProfile @relation(fields: [tradieProfileId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  jobId      String
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation(fields: [senderId], references: [id])
}

enum UserRole {
  HOMEOWNER
  TRADIE
  ADMIN
}

enum JobStatus {
  OPEN
  QUOTED
  BOOKED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  PENDING
  COMPLETED
  CANCELLED
  PENDING_CONFIRMATION
  DISPUTED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}
